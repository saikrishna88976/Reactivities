sts.post(\"/activities\", activity),\r\n  update: (activity: IActivity) =>\r\n    requests.put(`/activities/${activity.id}`, activity),\r\n  delete: (id: string) => requests.del(`/activities/${id}`),\r\n};\r\n\r\nexport default {\r\n  Activities,\r\n};\r\n","E:\\My_Projects\\Reactivities\\client-app\\src\\app\\layout\\LoadingComponent.tsx",[],"E:\\My_Projects\\Reactivities\\client-app\\src\\app\\stores\\ActivityStore.ts",[],"E:\\My_Projects\\Reactivities\\client-app\\src\\features\\home\\HomePage.tsx",[],"E:\\My_Projects\\Reactivities\\client-app\\src\\app\\layout\\ScrollToTop.tsx",[],{"ruleId":"67","replacedBy":"68"},{"ruleId":"69","replacedBy":"70"},{"ruleId":"67","replacedBy":"71"},{"ruleId":"69","replacedBy":"72"},{"ruleId":"73","severity":1,"message":"74","line":31,"column":1,"nodeType":"75","endLine":33,"endColumn":3},"no-native-reassign",["76"],"no-negated-in-lhs",["77"],["76"],["77"],"import/no-anonymous-default-export","Assign object to a variable before exporting as module default","ExportDefaultDeclaration","no-global-assign","no-unsafe-negation"]