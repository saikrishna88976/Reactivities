h2>;\r\n  }\r\n\r\n  return (\r\n    <Grid>\r\n      <Grid.Column width={10}>\r\n        <ActivityDetailsHeader activity={activity} />\r\n        <ActivityDetailsInfo activity={activity} />\r\n        <ActivityDetailsChat />\r\n      </Grid.Column>\r\n      <Grid.Column width={6}>\r\n        <ActivityDetailsSidebar />\r\n      </Grid.Column>\r\n    </Grid>\r\n  );\r\n};\r\n\r\nexport default observer(ActivityDetails);\r\n","E:\\My_Projects\\Reactivities\\client-app\\src\\features\\activities\\form\\ActivityForm.tsx",[],"E:\\My_Projects\\Reactivities\\client-app\\src\\app\\api\\agent.ts",["91"],"E:\\My_Projects\\Reactivities\\client-app\\src\\app\\layout\\LoadingComponent.tsx",[],"E:\\My_Projects\\Reactivities\\client-app\\src\\app\\stores\\ActivityStore.ts",[],"E:\\My_Projects\\Reactivities\\client-app\\src\\features\\home\\HomePage.tsx",[],"E:\\My_Projects\\Reactivities\\client-app\\src\\app\\layout\\ScrollToTop.tsx",[],"E:\\My_Projects\\Reactivities\\client-app\\src\\features\\activities\\dashboard\\ActivityListItem.tsx",[],"E:\\My_Projects\\Reactivities\\client-app\\src\\features\\activities\\details\\ActivityDetailsHeader.tsx",[],"E:\\My_Projects\\Reactivities\\client-app\\src\\features\\activities\\details\\ActivityDetailsInfo.tsx",[],"E:\\My_Projects\\Reactivities\\client-app\\src\\features\\activities\\details\\ActivityDetailsChat.tsx",[],"E:\\My_Projects\\Reactivities\\client-app\\src\\features\\activities\\details\\ActivityDetailsSidebar.tsx",[],"E:\\My_Projects\\Reactivities\\client-app\\src\\app\\layout\\NotFound.tsx",[],{"ruleId":"92","replacedBy":"93"},{"ruleId":"94","replacedBy":"95"},{"ruleId":"92","replacedBy":"96"},{"ruleId":"94","replacedBy":"97"},{"ruleId":"98","severity":1,"message":"99","line":6,"column":8,"nodeType":"100","messageId":"101","endLine":6,"endColumn":16},{"ruleId":"102","severity":1,"message":"103","line":53,"column":1,"nodeType":"104","endLine":55,"endColumn":3},"no-native-reassign",["105"],"no-negated-in-lhs",["106"],["105"],["10